@import "../css/colors.styl"

.carousel
  width auto
  height auto

  &__stage
    position relative
    overflow hidden

  &__item
    cursor pointer

    &.--slide-in
      position relative
      animation slide-in 0.5s ease forwards

    &.--slide-out
      position absolute
      top 0
      left 0
      width 100%
      animation slide-out 0.5s ease forwards


@keyframes slide-in {
  from {
    transform translateX(100%)
  }
  to {
    transform translateX(0)
  }
}

@keyframes slide-out {
  from {
    transform translateX(0)
  }
  to {
    transform translateX(-100%)
  }
}
