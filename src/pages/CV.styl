@import "../css/colors.styl"

small-screen-break-point = 950px

.cv
  width 100%
  padding 50px
  display flex
  flex-direction column
  font-size 14px
  box-sizing border-box

  &__about-me-content
    display flex
    flex-direction row
    align-items flex-start
    padding 20px

  &__image
    width 200px
    flex-shrink 0

  &__about-me-details
    flex 1
    padding-left 20px

  &__header
    font-size 30px
    font-weight bold
    margin-bottom 15px
    padding-bottom 10px
    border-bottom 1px solid #eee
    color c-pink

  &__about-me-description
    font-family 'Montserrat', sans-serif
    letter-spacing normal

    &.--emphasize
      font-size 16px

  &__block-spacing
    height 30px

  &__work-experiences, &__skills
    width 100%
    font-size 20px

  &__work-experiences-text, &__skills-text
    margin-top 3px
    margin-left 10px

  &__work-experiences-header, &__skills-header
    font-size 26px
    font-weight bold
    margin-bottom 20px

  &__work-experiences-title, &__skill-items
    padding-top 5px
    color c-pink

    .spacing
      height 12px

  &__work-experiences-company
    font-size 16px
    padding-left: 5px

@media print
  *
    -webkit-print-color-adjust exact
    print-color-adjust exact
    -webkit-font-smoothing antialiased
    text-rendering optimizeLegibility

  .cv
    padding 0

    &__block-spacing
      display none

    &__about-me-content
      padding 5px

    &__about-me-details
      padding-left 10px

    &__about-me .detail-list__item-icon
      padding 8px 15px

    &__about-me .detail-list__item-text
      padding 8px 10px 8px 0px

  .box-container
    box-shadow none !important
    border-radius 0
    border none

@media screen and (max-width: small-screen-break-point)
  .cv
    padding 10px

    &__about-me-content
      flex-direction column
      align-items center

    &__image
      width 100%
      max-width 315px

    &__about-me-details
      padding-left 0
      padding-top 15px
      width 100%
